{
    "name" : "Python Data Science Dev",

    "dockerComposeFile" : "docker-compose.yml",
    "service" : "app",
    "workspaceFolder" : "/workspace",

    "customizations" : {
        "vscode" : {
            "extensiones" : [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-python.vscode-pylance",
                "ms-vscode-remote.remote-containers",
                "ms-azuretools.vscode-containers",
                "ms-toolsai.datawrangler"
            ]
        }
    }, 

    "postCreateCommand" : "pip install pandas numpy psycopg2-binary matplotlib seaborn scikit-learn imbalanced-learn"
}